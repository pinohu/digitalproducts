{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:4175/index.html"
      ],
      "numberOfRuns": 1,
      "startServerCommand": "npm run preview:lighthouse",
      "startServerReadyPattern": "Available",
      "startServerReadyTimeout": 120000,
      "settings": {
        "preset": "desktop",
        "onlyCategories": [
          "performance",
          "accessibility",
          "best-practices",
          "seo"
        ]
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "document-latency-insight": "off",
        "network-dependency-tree-insight": "off",
        "uses-text-compression": "off",
        "is-crawlable": "off",
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:performance": [
          "warn",
          {
            "minScore": 0.75
          }
        ],
        "errors-in-console": [
          "error",
          {
            "minScore": 1
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
