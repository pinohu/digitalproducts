# Copy to tools/.env (gitignored) and fill in real values.

# Reddit (https://www.reddit.com/prefs/apps — create a "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=dynasty-empire-mining/1.0 by u/yourusername

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# GitHub PAT for future committing/pushing automation (optional for current local tools)
GITHUB_TOKEN=
GITHUB_REPO=pinohu/digitalproducts

# External platform credentials are intentionally not used directly by the current
# Python tools, but production automation still requires real account access:
# - n8n: configure credentials inside the n8n instance for workflow specs
# - Gumroad: account/API/workflow access for product publishing and emails
# - Neon: database URL if analytics aggregation is implemented against Neon
# - Vercel: token/project access if landing pages are deployed from automation

# n8n (required only when importing/activating workflows via API)
N8N_BASE_URL=
N8N_API_KEY=

# Gumroad (required only before product/storefront/workflow automation writes)
GUMROAD_ACCESS_TOKEN=

# Neon (required only before analytics/event persistence automation)
NEON_DATABASE_URL=

# Vercel (required only before landing-page deployment automation)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
