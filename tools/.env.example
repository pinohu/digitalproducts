# Copy to tools/.env (gitignored) and fill in real values.

# Reddit (https://www.reddit.com/prefs/apps — create a "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=dynasty-empire-mining/1.0 by u/yourusername

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# GitHub PAT for future committing/pushing automation (optional for current local tools)
GITHUB_TOKEN=
GITHUB_REPO=pinohu/digitalproducts

# Read-only AppSumo connector probes (optional; do not commit real values)
# Agiled: bearer token for GET-only checks against https://app.agiled.app/api/v1
AGILED_API_KEY=
# AITable.ai/APITable: bearer token for GET-only checks against https://aitable.ai/fusion/v1
AITABLE_API_KEY=
# Emailit: bearer token for GET-only checks against https://api.emailit.com/v2
# Use --secret-name if testing an alternate runtime key name; never use this for sends/mutations.
EMAILIT_API_KEY=
# Certopus: X-API-KEY value for GET-only checks against https://api.certopus.com.
# For scheduled n8n, prefer a dedicated automation-owned key/env named CERTOPUS_API_KEY_AUTOMATION.
CERTOPUS_API_KEY=
CERTOPUS_API_KEY_AUTOMATION=
# Boost.space: bearer token for tenant-shaped API checks. Requires --base-url https://<system>.boost.space/api.
BOOST_SPACE_API_KEY=
# Flowlu: API key for tenant-shaped API checks. Requires --base-url https://<company>.flowlu.com/api/v1/module.
FLOWLU_API_KEY=
# Procesio: Web API uses separate key/value headers, so the API key name and value are both required.
# PROCESIO_API_KEY is the value header; PROCESIO_API_KEY_NAME is the non-secret-ish key-name label passed via --api-key-name.
# Workspace-scoped reads may also require --workspace / a runtime-only workspace header value.
PROCESIO_API_KEY=
PROCESIO_API_KEY_NAME=

# External platform credentials are intentionally not used directly by most local
# Python tools, but production automation still requires real account access:
# - n8n: configure credentials inside the n8n instance for workflow specs
# - Gumroad: account/API/workflow access for product publishing and emails
# - Neon: database URL if analytics aggregation is implemented against Neon
# - Vercel: token/project access if landing pages are deployed from automation

# n8n (required only when importing/activating workflows via API)
N8N_BASE_URL=
N8N_API_KEY=

# Gumroad (required only before product/storefront/workflow automation writes)
GUMROAD_ACCESS_TOKEN=

# Neon (required only before analytics/event persistence automation)
NEON_DATABASE_URL=

# Vercel (required only before landing-page deployment automation)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
