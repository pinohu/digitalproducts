{
  "name": "Launch Automation",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "launch/start",
        "authentication": "headerAuth",
        "options": {
          "responseMode": "onReceived",
          "responseData": "Launch started"
        }
      },
      "id": "73903db5-2bd6-4b3e-a11a-72ba5309950b",
      "name": "Webhook — Launch Start",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 300],
      "credentials": {
        "httpHeaderAuth": {"id": "REPLACE_ME", "name": "Launch Webhook Bearer Token"}
      },
      "webhookId": "7ee7a268-13ec-4c6f-bd1e-11ff51f41a8d"
    },
    {
      "parameters": {
        "jsCode": "// Pull required launch parameters from the webhook body and fail fast\n// if anything is missing. The downstream HTTP nodes use these values\n// directly via expressions.\nconst body = items[0].json.body || items[0].json;\nconst { product_slug, launch_datetime, founding_price_expires } = body;\nif (!product_slug || !launch_datetime || !founding_price_expires) {\n  throw new Error('Missing required field: product_slug, launch_datetime, or founding_price_expires');\n}\nreturn [{\n  json: {\n    product_slug,\n    launch_datetime,\n    founding_price_expires,\n    offer_path: `02-offers/by-product/${product_slug}.md`,\n    sales_path: `04-sales-pages/by-product/${product_slug}.md`,\n    emails_path: `05-email-workflows/by-product/${product_slug}/launch-sequence.md`\n  }\n}];"
      },
      "id": "5e5e8cff-5f77-4606-a771-1f31f87d883e",
      "name": "Extract Launch Params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/repos/pinohu/digitalproducts/contents/{{ $json.offer_path }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "80b9b08f-bdd9-46b8-a9aa-02b2913b73b4",
      "name": "GitHub — Load Offer Brief",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 200],
      "credentials": {
        "httpHeaderAuth": {"id": "REPLACE_ME", "name": "GitHub PAT (Bearer)"}
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/repos/pinohu/digitalproducts/contents/{{ $node['Extract Launch Params'].json.sales_path }}",
