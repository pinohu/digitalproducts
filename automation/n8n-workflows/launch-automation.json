    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.github.com/repos/pinohu/digitalproducts/contents/{{ $node['Extract Launch Params'].json.emails_path }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "db5cabf4-55a1-4b8b-8aa0-abfd1475c195",
      "name": "GitHub — Load Email Sequence",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 400],
      "credentials": {
        "httpHeaderAuth": {"id": "REPLACE_ME", "name": "GitHub PAT (Bearer)"}
      }
    },
    {
      "parameters": {
        "jsCode": "// Validate that all three context files were loaded and that the\n// email sequence is not still using template placeholders. Returns a\n// single item carrying the parsed email bodies plus a `valid` flag.\nconst all = $input.all();\nconst offer = all[0]?.json;\nconst sales = all[1]?.json;\nconst emails = all[2]?.json;\nconst params = $node['Extract Launch Params'].json;\n\nconst missing = [];\nif (!offer?.content) missing.push('offer brief');\nif (!sales?.content) missing.push('sales page');\nif (!emails?.content) missing.push('launch sequence');\n\nlet emailBody = '';\nif (emails?.content) {\n  emailBody = Buffer.from(emails.content, 'base64').toString('utf-8');\n}\n// Parse the launch-sequence.md file: we expect 8 sections each starting\n// with '## Email N' headers. Any section that still contains the literal\n// '[PLACEHOLDER]' marker is treated as un-drafted.\nconst sections = emailBody.split(/\\n## Email \\d+/);\n// sections[0] is the preamble; emails are sections[1..].\nconst emailSections = sections.slice(1).map((s, i) => ({\n  index: i + 1,\n  body: s.trim()\n}));\nconst placeholders = emailSections.filter(e => /\\[PLACEHOLDER\\]/i.test(e.body));\nconst valid = missing.length === 0 && emailSections.length >= 7 && placeholders.length === 0;\n\nreturn [{\n  json: {\n    valid,\n    missing,\n    placeholder_count: placeholders.length,\n    email_count: emailSections.length,\n    emails: emailSections,\n    product_slug: params.product_slug,\n    launch_datetime: params.launch_datetime,\n    founding_price_expires: params.founding_price_expires\n  }\n}];"
      },
