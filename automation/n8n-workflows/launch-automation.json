        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "f5c680d3-078b-4b12-9274-af262d3227f1",
      "name": "GitHub — Load Sales Page",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "credentials": {
